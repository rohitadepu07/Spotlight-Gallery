{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../src/shared/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
